{
  "name": "loadout-lab",
  "version": "1.0.0",
  "description": "A physics-based tennis equipment analysis tool. Pick a racquet, string, and tension — the engine predicts how your setup will play across nine attributes (power, spin, control, comfort, feel, stability, forgiveness, launch, maneuverability).",
  "private": true,
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "test:runtime": "tsx tests/runtime-hardening.test.ts",
    "extract": "tsx pipeline/scripts/extract.ts",
    "validate": "tsx pipeline/scripts/validate.ts",
    "export": "tsx pipeline/scripts/export-to-app.ts",
    "export:verify": "tsx pipeline/scripts/export-to-app.ts --verify",
    "canary": "tsx pipeline/scripts/canary-test.ts",
    "canary:baseline": "tsx pipeline/scripts/canary-test.ts --baseline",
    "estimate": "tsx pipeline/scripts/estimate.ts",
    "calibrate": "tsx pipeline/scripts/calibrate.ts",
    "ingest:frame": "tsx pipeline/scripts/ingest.ts --type frame",
    "ingest:string": "tsx pipeline/scripts/ingest.ts --type string",
    "pipeline": "npm run validate && npm run export:verify",
    "scrape:twu": "tsx pipeline/scripts/scrape-twu.ts",
    "scrape:twu-strings": "tsx pipeline/scripts/scrape-twu-strings.ts",
    "enrich:twu": "tsx pipeline/scripts/enrich-twu-csv.ts"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:38515/git/zaldytb/loadout-lab"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "json5": "^2.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
